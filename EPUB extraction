
#!/usr/bin/env python3
"""
Convert a directory of extracted book chapters (markdown files) into a
single EPUB.
 
Expects each chapter file to look like the scraper's output format:
 
    Title: Chapter Title
    Source: https://example.com/...
    Lesson: 3
 
    ---
 
    # Chapter Title
    ...body...
 
The leading `Title:`/`Source:`/`Lesson:` header block (everything before
the `---` separator) is stripped before the files are handed to pandoc,
so it doesn't leak into the rendered book as visible text.
 
Requires the `pandoc` binary to be installed and on PATH.
"""
 
from __future__ import annotations
 
import argparse
import re
import subprocess
import sys
import tempfile
from pathlib import Path
 
# Matches the metadata header block at the top of a chapter file, up to
# and including the first line that is just "---". Allows blank lines
# between the metadata lines and the "---" separator.
_HEADER_RE = re.compile(
    r"\A(?:^(?:Title|Source|Lesson):.*\n)+\s*^---[ \t]*\n?",
    re.MULTILINE,
)
 
# Fallback: grabs the value after "Title:" on the first line, used when
# no --title is passed to name the book / order chapters in the TOC.
_TITLE_LINE_RE = re.compile(r"^Title:\s*(.+)$", re.MULTILINE)
 
 
def strip_chapter_header(text: str) -> tuple[str, str | None]:
    """Remove the Title/Source/Lesson metadata header from one chapter.
 
    Returns (body_without_header, chapter_title_or_None).
    """
    title_match = _TITLE_LINE_RE.search(text)
    chapter_title = title_match.group(1).strip() if title_match else None
 
    body = _HEADER_RE.sub("", text, count=1).lstrip("\n")
    return body, chapter_title
 
 
def natural_sort_key(path: Path):
    """Sort '2-foo.md' before '10-foo.md' by pulling out leading digits."""
    m = re.match(r"^(\d+)", path.stem)
    return (int(m.group(1)) if m else float("inf"), path.stem)
 
 
def collect_chapters(book_dir: Path, pattern: str = "*.md") -> list[Path]:
    files = sorted(book_dir.glob(pattern), key=natural_sort_key)
    if not files:
        raise FileNotFoundError(f"No files matching {pattern!r} found in {book_dir}")
    return files
 
 
def build_epub(
    book_dir: str | Path,
    output_path: str | Path,
    title: str | None = None,
    author: str | None = None,
    language: str = "en",
    pattern: str = "*.md",
    cover_image: str | Path | None = None,
) -> Path:
    """Merge every chapter file in book_dir into a single EPUB.
 
    book_dir:     directory containing the extracted chapter .md files
    output_path:  where to write the .epub
    title:        book title (falls back to the first chapter's "Title:" line,
                  or the directory name)
    author:       optional author metadata
    pattern:      glob pattern for chapter files, default "*.md"
    cover_image:  optional path to a cover image (jpg/png)
    """
    book_dir = Path(book_dir)
    output_path = Path(output_path)
    chapter_files = collect_chapters(book_dir, pattern)
 
    with tempfile.TemporaryDirectory() as tmp:
        tmp = Path(tmp)
        merged_parts = []
        inferred_title = None
 
        for i, f in enumerate(chapter_files):
            raw = f.read_text(encoding="utf-8")
            body, chapter_title = strip_chapter_header(raw)
            if i == 0 and chapter_title:
                inferred_title = chapter_title
            merged_parts.append(body.strip())
 
        merged_md = "\n\n".join(merged_parts) + "\n"
        merged_file = tmp / "book.md"
        merged_file.write_text(merged_md, encoding="utf-8")
 
        final_title = title or inferred_title or book_dir.name.replace("-", " ").title()
 
        cmd = [
            "pandoc",
            str(merged_file),
            "-o", str(output_path),
            "--metadata", f"title={final_title}",
            "--metadata", f"lang={language}",
            "--toc",
            "--toc-depth=2",
        ]
        if author:
            cmd += ["--metadata", f"author={author}"]
        if cover_image:
            cmd += [f"--epub-cover-image={cover_image}"]
 
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            raise RuntimeError(f"pandoc failed:\n{result.stderr}")
 
    return output_path
 
 
def main():
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("book_dir", help="Directory containing extracted chapter .md files")
    parser.add_argument("-o", "--output", required=True, help="Output .epub path")
    parser.add_argument("--title", help="Book title (default: inferred from first chapter)")
    parser.add_argument("--author", help="Author name")
    parser.add_argument("--language", default="en", help="Language code (default: en)")
    parser.add_argument("--pattern", default="*.md", help="Glob pattern for chapter files (default: *.md)")
    parser.add_argument("--cover", help="Path to cover image")
    args = parser.parse_args()
 
    out = build_epub(
        args.book_dir,
        args.output,
        title=args.title,
        author=args.author,
        language=args.language,
        pattern=args.pattern,
        cover_image=args.cover,
    )
    print(f"Wrote {out}")
 
 
if __name__ == "__main__":
    main()
